# Local .terraform directories
**/.terraform/*
.terraform-cache/
.artifacts/
.codex/

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data, such as
# password, private keys, and other secrets. These should not be part of version 
# control as they are data points which are potentially sensitive and subject 
# to change depending on the environment.
*.tfvars
*.tfvars.json

# Ignore override files as they are usually used to override resources locally and so
# are not checked in
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Include tfplan files to ignore the plan output of command: terraform plan -out=tfplan
*tfplan*

# CLI configuration files
.terraformrc
terraform.rc

# Sensitive certificates and keys
*.pem
*.key
*.crt
certs/
secrets/
.env
.env.*
*.p12
*.pfx

# Kubernetes / local proxy sensitive files
proxy.json
*.kubeconfig
kubeconfig

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDEs and Editors
.idea/
.vscode/
*.swp
*.swo

# Node.js
node_modules/
npm-debug.log
yarn-error.log
dist/
build/

# Python
__pycache__/
*.py[cod]

# Pulumi
.pulumi/
