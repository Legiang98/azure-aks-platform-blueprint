{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/platform-settings.schema.json",
  "title": "AKS Platform Settings",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "platform"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "platform.settings/v1"
    },
    "platform": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tenant",
        "app",
        "service",
        "environment"
      ],
      "properties": {
        "tenant": {
          "type": "string",
          "minLength": 1
        },
        "app": {
          "type": "string",
          "minLength": 1
        },
        "service": {
          "type": "string",
          "minLength": 1
        },
        "environment": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "keyVault": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "urlEnv": {
          "type": "string",
          "default": "PLATFORM_KEY_VAULT_URL"
        },
        "secretMappings": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "name",
              "env",
              "secretName"
            ],
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "env": {
                "type": "string",
                "minLength": 1
              },
              "secretName": {
                "type": "string",
                "minLength": 1
              },
              "required": {
                "type": "boolean",
                "default": true
              }
            }
          }
        }
      }
    },
    "dependencies": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "services": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "url"
            ],
            "properties": {
              "url": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    },
    "features": {
      "type": "object",
      "additionalProperties": {
        "type": [
          "boolean",
          "string",
          "number"
        ]
      }
    }
  }
}
